# Twilio credentials (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token

# Optional. When set, outbound messages route through this Messaging Service.
# Twilio picks the optimal sender from the pool (e.g. 10DLC for US, toll-free
# for international). Leave blank to send directly from TWILIO_PHONE_NUMBER.
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp sender (leave blank for SMS-only; configure both for multi-channel)
# TWILIO_WHATSAPP_NUMBER=+14155238886
# TWILIO_WHATSAPP_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_DELIVERY=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_RATING=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_PROMO=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TEMPLATE_NUDGE=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public, non-person sample used when submitting the delivery image template.
# TWILIO_TEMPLATE_SAMPLE_PORTRAIT_PATH=assets/template-samples/sample-portrait.jpg

# OpenAI API key (from https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_key

# Printer name (run `lpstat -p` to list available printers)
PRINTER_NAME=your_printer_name

# Event config
EVENT_NAME=YourEventName
ADMIN_PHONES=+1234567890,+0987654321
MAX_PRINTS_PER_USER=2
MAX_CONCURRENT_GENERATION=15

# Model overrides (optional -- defaults to latest recommended models)
# MODEL_ORCHESTRATOR=gpt-5.4
# MODEL_VISION_LIGHT=gpt-5.4-nano
# MODEL_IMAGE_GEN=gpt-image-2-2026-04-21
# MODEL_SMART_REPLY=gpt-5.4-nano

# Template frame (optional -- leave blank to disable)
TEMPLATE_FILE=signal_sf.png

# Legal
TERMS_URL=https://example.com/terms

# Promotional message (optional -- sent as standalone SMS after each portrait)
PROMO_MESSAGE=

# Print Relay (for cloud printing -- run `pnpm relay` on the event laptop)
# PRINT_RELAY_URL=https://your-app.azurecontainerapps.io
# PRINT_RELAY_KEY=your-shared-secret

# dub.co URL shortening (optional -- enables short share links like twil.io/signal-1)
# DUB_API_KEY=your-dub-api-key
# DUB_DOMAIN=twil.io
# DUB_FOLDER_ID=

# Google OAuth (optional -- protects /dashboard and /outreach with @twilio.com login)
# Create credentials at: Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client ID
# Add redirect URI: http://localhost:3000/auth/callback (and your production URL)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# SESSION_SECRET=random-secret-string
