{
  "name": "print-relay",
  "productName": "Twilio Print Station",
  "version": "1.1.0",
  "description": "Electron GUI for the Twilio AI Photobooth print relay agent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Twilio Print Station",
        "icon": "./build/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["darwin"]
        }
      ]
    }
  }
}
